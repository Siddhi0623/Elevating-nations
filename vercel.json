{
  "version": 2,
  "buildCommand": "npm install",
  "outputDirectory": "public",
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/contact",
      "destination": "/contact.html"
    },
    {
      "source": "/contact.html",
      "destination": "/contact.html"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
