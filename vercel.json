{
  "version": 2,
  "name": "elevating-nations",
  "public": true,
  "buildCommand": "npm install",
  "outputDirectory": "public",
  "env": {
    "NODE_ENV": "production",
    "WHATSAPP_PHONE": "@whatsapp_phone"
  },
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs18.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/contact",
      "destination": "/contact.html"
    },
    {
      "source": "/contact.html",
      "destination": "/contact.html"
    },
    {
      "source": "/:path((?!api/|.*\\..*).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
